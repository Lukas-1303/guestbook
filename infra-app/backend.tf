# ==============================================================================
# Terraform Backend Configuration
# ==============================================================================
# "학원 컴퓨터"와 "집 컴퓨터" 양쪽에서 자유롭게 인프라를 껐다 켜기(apply/destroy) 위해
# 테라폼 작업 내역서(tfstate)를 내 컴퓨터 하드디스크가 아닌 AWS S3에 안전하게 보관합니다.

terraform {
  backend "s3" {
    key    = "infra-app/terraform.tfstate"
    region = "ap-northeast-1"
    # 버킷 이름은 깃허브 노출 방지를 위해 init 명령어 시점에 주입합니다.
    
    # 1인 개발이므로 락킹(DynamoDB)은 생략해도 무방합니다.
  }
}
